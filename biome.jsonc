{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noForEach": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 140
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "none",
      "semicolons": "always"
    }
  },
  "css": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space"
    }
  },
  "assist": {
    "enabled": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.css",
      "!!**/dist",
      "!!**/build",
      "!!**/.live-smoke-artifacts",
      "!!**/.oss-corpus-artifacts",
      "!!**/node_modules",
      "!!.next",
      "!out",
      "!pnpm-lock.yaml",
      "!**/raw",
      "!**/wiki",
      "!**/state",
      "!**/agent",
      "!**/inbox",
      "!!**/.claude",
      "!!**/.cursor",
      "!!**/.agents"
    ]
  }
}
